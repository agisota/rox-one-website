---
import '../styles/global.css'
import { getReleaseSummary } from '../lib/release'

const { releases } = await getReleaseSummary()

function fmtDate(iso: string): string {
    if (!iso) return ''
    const d = new Date(iso)
    return d.toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'short',
        day: 'numeric',
    })
}
---

<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="theme-color" content="#08090C" />
        <title>Changelog — ROX.ONE</title>
        <meta name="description" content="Release history for ROX.ONE Terminal." />
        <link rel="canonical" href="https://rox.one/changelog/" />
        <link rel="alternate" type="application/rss+xml" title="ROX.ONE releases" href="/feed.xml" />
    </head>
    <body>
        <div class="changelog-page">
            <h1>Changelog</h1>
            <p class="changelog-intro">
                Release history for ROX.ONE Terminal. Full notes on
                <a href="https://github.com/agisota/rox-one-terminal/releases" style="color: inherit">GitHub</a>.
            </p>

            {releases.length === 0 && (
                <p style="color: rgba(245,244,239,0.4)">
                    Releases will appear here once the first build runs against a live tag.
                </p>
            )}

            {releases.map((r) => (
                <article class="changelog-entry">
                    <h2>
                        <a href={r.htmlUrl} target="_blank" rel="noreferrer">
                            {r.name || r.tag}
                        </a>
                    </h2>
                    <div class="changelog-meta">
                        <span>{r.tag}</span>
                        {r.publishedAt && <span> · {fmtDate(r.publishedAt)}</span>}
                    </div>
                    {r.bodyText && <div class="changelog-body">{r.bodyText}</div>}
                </article>
            ))}

            <a href="/" class="changelog-back">← на главную</a>
        </div>
    </body>
</html>
