{
  "name": "rox-one-website",
  "description": "Сайт ROX ONE — agent-native терминал для работы с самыми мощными LLM. Astro 5 + vanilla TypeScript; no framework runtime ships to the client.",
  "version": "0.3.0",
  "author": "ROX ONE",
  "license": "MIT",
  "engines": {
    "node": "22.x"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/agisota/rox-one-website"
  },
  "private": true,
  "type": "module",
  "scripts": {
    "build": "astro build",
    "dev": "astro dev --host 0.0.0.0 --port 8001",
    "develop": "astro dev --host 0.0.0.0 --port 8001",
    "start": "astro dev --host 0.0.0.0 --port 8001",
    "serve": "astro preview --host 0.0.0.0",
    "clean": "rm -rf dist .astro",
    "format": "prettier --write \"**/*.{html,js,ts,tsx,astro,json,css,scss}\"",
    "typecheck": "astro check",
    "test:e2e": "playwright test",
    "prepare": "husky",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@fontsource-variable/geist": "^5.2.8",
    "@tailwindcss/vite": "^4.1.16",
    "astro": "^5.16.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.16",
    "typescript": "^5.6.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@axe-core/playwright": "^4.11.3",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.50.0",
    "husky": "^9.1.7",
    "prettier": "^2.1.0"
  },
  "packageManager": "pnpm@10.23.0+sha512.21c4e5698002ade97e4efe8b8b4a89a8de3c85a37919f957e7a0f30f38fbc5bbdd05980ffe29179b2fb6e6e691242e098d945d1601772cad0fef5fb6411e2a4b"
}
